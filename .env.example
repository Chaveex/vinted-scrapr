ANTHROPIC_API_KEY=your_api_key_here
PORT=8000

# Vinted auth — one of these two methods:
# OPTION A (mobile app): Bearer token from app traffic
VINTED_TOKEN=
# OPTION B (browser, easier): copy full Cookie header from DevTools
# F12 → Network → search NFL → click api/v2 request → Request Headers → Cookie
VINTED_COOKIE=
